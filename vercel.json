{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/edit",
      "destination": "/dashboard.html"
    },
    {
      "source": "/api/auth/login",
      "destination": "/system/api/auth_login"
    },
    {
      "source": "/api/auth/register",
      "destination": "/system/api/auth_register"
    },
    {
      "source": "/api/admin/users",
      "destination": "/system/api/admin_users"
    },
    {
      "source": "/api/admin/create_badge",
      "destination": "/system/api/admin_create_badge"
    },
    {
      "source": "/api/admin/delete_user",
      "destination": "/system/api/admin_delete_user"
    },
    {
      "source": "/api/admin/get_badges",
      "destination": "/system/api/admin_get_badges"
    },
    {
      "source": "/api/admin/set_badges",
      "destination": "/system/api/admin_set_badges"
    },
    {
      "source": "/api/admin/delete_badge",
      "destination": "/system/api/admin_delete_badge"
    },
    {
      "source": "/api/admin/set_role",
      "destination": "/system/api/admin_set_role"
    },
    {
      "source": "/api/admin/migrate",
      "destination": "/system/api/admin_migrate"
    },
    {
      "source": "/api/user/profile",
      "destination": "/system/api/user_profile"
    },
    {
      "source": "/api/user/change-username",
      "destination": "/system/api/user_change_username"
    },
    {
      "source": "/api/user/change-password",
      "destination": "/system/api/user_change_password"
    },
    {
      "source": "/api/profile/update",
      "destination": "/system/api/profile_update"
    },
    {
      "source": "/api/force_admin",
      "destination": "/system/api/temp_promote"
    },
    {
      "source": "/((?!api|assets|css|js|system|p|favicon\\.ico|robots\\.txt|.*\\.html|.*\\.js|.*\\.css).*)$",
      "destination": "/profile.html?u=$1"
    }
  ]
}