{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/edit", "destination": "/dashboard.html" },
    
    { "source": "/api/auth/login", "destination": "/api/auth_login" },
    { "source": "/api/auth/register", "destination": "/api/auth_register" },
    { "source": "/api/admin/users", "destination": "/api/admin_users" },
    { "source": "/api/admin/create_badge", "destination": "/api/admin_create_badge" },
    { "source": "/api/admin/delete_user", "destination": "/api/admin_delete_user" },
    { "source": "/api/admin/get_badges", "destination": "/api/admin_get_badges" },
    { "source": "/api/admin/set_badges", "destination": "/api/admin_set_badges" },
    { "source": "/api/admin/set_role", "destination": "/api/admin_set_role" },
    { "source": "/api/admin/migrate", "destination": "/api/admin_migrate" },
    { "source": "/api/user/profile", "destination": "/api/user_profile" },
    { "source": "/api/user/change-username", "destination": "/api/user_change_username" },
    { "source": "/api/user/change-password", "destination": "/api/user_change_password" },
    { "source": "/api/profile/update", "destination": "/api/profile_update" },
    { "source": "/api/force_admin", "destination": "/api/temp_promote" },

    {
      "source": "/((?!api|assets|css|js|system|p|favicon\\.ico|robots\\.txt|.*\\.html|.*\\.js|.*\\.css).*)$",
      "destination": "/profile.html?u=$1"
    }
  ]
}
